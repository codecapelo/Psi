# ==========================================================================
# SOPsi 2.0 — variáveis de ambiente
# Copie para .env (local) e configure no Railway (Variables).
# ==========================================================================

# Porta do servidor Express (Railway injeta automaticamente em produção)
PORT=8080

# Banco de dados — Neon (Postgres). String de conexão com SSL.
# Ex.: postgresql://user:senha@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# OpenAI — chave da API e modelos.
OPENAI_API_KEY=
# Modelo de texto padrão (chat, síntese, sugestões). Ex.: gpt-4o, gpt-4o-mini, gpt-4.1
OPENAI_MODEL=gpt-4o
# Modelo de transcrição de áudio. Ex.: whisper-1, gpt-4o-transcribe
OPENAI_TRANSCRIBE_MODEL=whisper-1

# Modo de ambiente
NODE_ENV=production

# ==========================================================================
# AUTENTICAÇÃO E SEGURANÇA  ⚠️ OBRIGATÓRIO EM PRODUÇÃO
# ==========================================================================

# Profissionais autorizados, no formato "email:senha" separados por vírgula.
# Enquanto AUTH_USERS estiver VAZIO, a API fica SEM autenticação (apenas dev).
# Use senhas fortes e únicas; estas credenciais são o segredo do sistema.
# Ex.: AUTH_USERS=dra.ana@clinica.com:SenhaForte!23,dr.bruno@clinica.com:Outra#456
AUTH_USERS=

# Segredo para assinar os tokens de sessão (>= 32 caracteres). Se ausente ou
# mais curto, um segredo efêmero é gerado a cada boot (todos são deslogados ao
# reiniciar). Gere um valor aleatório, ex.: openssl rand -hex 32
JWT_SECRET=

# Validade do token de sessão em segundos (padrão 43200 = 12h).
AUTH_TOKEN_TTL=43200

# Origens permitidas para CORS (lista separada por vírgula). Vazio = same-origin
# apenas (recomendado, pois o próprio Express serve o frontend).
CORS_ORIGIN=

# Defina como "off" apenas para diagnosticar quebras de CSP (não use em produção).
# HELMET_CSP=off

# (Opcional) E-mails com permissão de escrita nas memórias clínicas (MOSP).
# Lista separada por vírgula. Vazio = qualquer usuário autenticado pode editar.
MOSP_AUTHORS=

# Administradores: veem a TRILHA DE AUDITORIA completa E podem APAGAR todos os
# dados (LGPD /privacy/wipe). Lista de e-mails por vírgula. Recomendado em
# instalações multiusuário. Default quando vazio: modo aberto (dev) ou usuário
# único => esse usuário é admin; múltiplos usuários => ninguém é admin.
ADMIN_USERS=
